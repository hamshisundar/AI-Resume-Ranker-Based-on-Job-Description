# Copy to `.env` in this folder (never commit `.env`). Values are read by python-dotenv.

# Required in production — use a long random string
# SECRET_KEY=

# SQLite default; use postgres+psycopg2://... in production if you migrate
# DATABASE_URL=sqlite:////absolute/path/to/instance/app.db

# Comma-separated browser origins allowed to send cookies (must match your frontend URL)
# CORS_ORIGINS=https://your-app.example.com

# Session cookie only sent over HTTPS when true
# SESSION_COOKIE_SECURE=true

# Set false only for local API testing without login
# REQUIRE_AUTH=true

# API port (run.py / gunicorn bind is separate)
# PORT=5050

# Trained model files directory (relative to backend/ or absolute)
# ARTIFACTS_DIR=artifacts
